{
  "name": "green-galaxy",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "git diff --quiet src/lib/books-cache.json || git add src/lib/books-cache.json",
