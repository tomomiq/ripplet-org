  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "@anthropic-ai/sdk": "^0.39.0"
  }
}
