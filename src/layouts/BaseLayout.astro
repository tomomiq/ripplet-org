---
interface Props {
  title: string;
  rssUrl?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
}
const { title, description, canonicalUrl, ogImage, rssUrl } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Hi, my name is Tomomi.</title>
  {description && <meta name="description" content={description} />}
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
  <meta property="og:title" content={`${title} — Hi, my name is Tomomi.`} />
  {description && <meta property="og:description" content={description} />}
  {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
  <meta property="og:type" content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {rssUrl && <link rel="alternate" type="application/rss+xml" title="Weeknotes - Tomomi Sasaki" href={rssUrl} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script defer src="https://umami-sooty-six.vercel.app/script.js" data-website-id="d1047869-4802-43a3-9ba8-a2fcc802cc8e"></script>
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }

  body {
    margin: 0;
    overflow-x: hidden;
    font-family: 'DM Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 16px;
    line-height: 1.7em;
    color: #222;
    background: #fff;
  }

  a { color: #222; text-decoration: underline; }
  a:hover { opacity: 0.6; }

  h1, h2, h3 { line-height: 1.3; }
  h1 { font-size: 38px; font-weight: 700; margin: 0 0 36px; }

  @media (max-width: 768px) {
    h1 { font-size: 26px; margin: 0 0 24px; }
  }

  p { margin: 0 0 20px; }
  p:last-child { margin-bottom: 0; }

  ul { margin: 0 0 20px; padding-left: 22px; }
  ul li { margin-bottom: 6px; }

  blockquote {
    border-left: 3px solid #ddd;
    margin: 0 0 20px;
    padding: 4px 0 4px 20px;
    color: #555;
    font-style: italic;
  }
  blockquote p { margin-bottom: 0; }

  hr {
    border: none;
    margin: 20px 0;
    text-align: center;
  }
  hr::before {
    content: '◆';
    display: inline-block;
    color: #999;
    font-size: 13px;
    letter-spacing: 2px;
  }
</style>
