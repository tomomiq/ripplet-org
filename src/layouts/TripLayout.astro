---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import NewsletterFooter from '../components/NewsletterFooter.astro';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  nextPeer?: { title: string; permalink: string } | null;
  prevPeer?: { title: string; permalink: string } | null;
}
const { title, description, canonicalUrl, nextPeer, prevPeer } = Astro.props;
---
<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
>
  <Header currentPath="/trips" />
  <main>
    <div class="trip-content">
      <slot />
    </div>
    {(prevPeer || nextPeer) && (
      <nav class="trip-nav">
        {prevPeer ? <a class="trip-nav-prev" href={prevPeer.permalink}>← {prevPeer.title}</a> : <span />}
        {nextPeer ? <a class="trip-nav-next" href={nextPeer.permalink}>{nextPeer.title} →</a> : <span />}
      </nav>
    )}
    <div class="trip-footer">
      <NewsletterFooter />
    </div>
  </main>
</BaseLayout>

<style>
  .trip-content {
    max-width: 960px;
    margin: 0 auto;
    padding: 40px 30px 0;
  }

  .trip-content :global(iframe) {
    display: block;
    width: 100%;
    margin: 1.5rem 0;
  }

  /* Image galleries */
  .trip-content :global(.image-grid .image-row) {
    display: contents;
  }

  .trip-content :global(.image-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin: 1.5rem 0;
  }

  .trip-content :global(.image-grid.cols-4) {
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .trip-content :global(.image-grid img) {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    margin: 0;
  }

  .trip-content :global(.image-grid > p) {
    display: none;
  }

  .trip-content :global(.image-grid figure) {
    margin: 0;
  }

  .trip-content :global(figcaption) {
    font-size: 12px;
    color: #999;
    margin-top: 4px;
  }

  /* Single images */
  .trip-content :global(figure:not(.image-grid figure)) {
    margin: 1rem 0;
  }

  .trip-content :global(figure:not(.image-grid figure) img) {
    max-width: 100%;
    height: auto;
    display: block;
  }

  /* Column layouts */
  .trip-content :global(.col-1-1) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
    margin: 1.5rem 0;
  }

  .trip-content :global(.col-2-1) {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    align-items: start;
    margin: 1.5rem 0;
  }

  .trip-content :global(.col-1-1 figure),
  .trip-content :global(.col-2-1 figure) {
    margin: 0;
  }

  .trip-content :global(.col-1-1 figure img),
  .trip-content :global(.col-2-1 figure img),
  .trip-content :global(.col-1-1 img),
  .trip-content :global(.col-2-1 img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .trip-content :global(.col-1-1 > *:first-child),
  .trip-content :global(.col-2-1 > *:first-child) {
    margin-top: 0;
  }

  .trip-content :global(.col-1-1 > div > *:first-child),
  .trip-content :global(.col-2-1 > div > *:first-child) {
    margin-top: 0;
  }

  .trip-content :global(.col-1-1 iframe),
  .trip-content :global(.col-2-1 iframe) {
    margin: 0;
  }

  @media (max-width: 768px) {
    .trip-content :global(.col-1-1),
    .trip-content :global(.col-2-1) {
      grid-template-columns: 1fr;
    }
  }

  .trip-nav {
    display: flex;
    justify-content: center;
    gap: 48px;
    align-items: center;
    max-width: 960px;
    margin: 140px auto 80px;
    padding: 0 30px;
    font-size: 14px;
  }

  .trip-nav-prev,
  .trip-nav-next {
    color: inherit;
  }

  .trip-nav-prev:hover,
  .trip-nav-next:hover { opacity: 0.6; }

  .trip-footer {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 30px;
  }

  @media (max-width: 480px) {
    .trip-content { padding: 20px 16px 0; }
    .trip-nav { padding: 0 16px; margin-top: 44px; }
    .trip-content :global(.image-grid) {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
