---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import NewsletterFooter from '../../components/NewsletterFooter.astro';

const trips = await getCollection('trips');
const sorted = trips.sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
---

<BaseLayout
  title="Trips"
  description="Cycling, hiking, and racing trip reports."
  canonicalUrl="https://www.ripplet.org/trips"
>
  <Header currentPath="/trips" />
  <main>
    <div class="page-content">
      <h1 class="entry-title">Trips</h1>
      <ul class="trip-list">
        {sorted.map(trip => (
          <li>
            <a href={`/trips/${trip.id}`}>{trip.data.title}</a>
            {trip.data.year && <span class="year">{trip.data.year}</span>}
          </li>
        ))}
      </ul>
      <NewsletterFooter />
    </div>
  </main>
</BaseLayout>

<style>
  .page-content {
    max-width: 840px;
    margin: 0 auto;
    padding: 60px 30px 80px;
  }
  h1.entry-title {
    font-size: 38px;
    font-weight: 700;
    margin: 0 0 36px;
    text-align: center;
  }
  .trip-list {
    list-style: none;
    padding: 0;
    margin: 0 0 48px;
  }
  .trip-list li {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid #eee;
  }
  .trip-list a {
    color: inherit;
    text-decoration: underline;
    font-size: 18px;
  }
  .trip-list a:hover { opacity: 0.6; }
  .year {
    font-size: 13px;
    color: #999;
  }
  @media (max-width: 768px) {
    .page-content { padding: 40px 20px 60px; }
    h1.entry-title { font-size: 26px; margin: 0 0 24px; }
    .trip-list a { font-size: 16px; }
  }
</style>
