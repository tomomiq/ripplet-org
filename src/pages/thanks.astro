---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---
<BaseLayout title="Thanks" canonicalUrl="https://www.ripplet.org/thanks">
  <Header currentPath="/contact" />
  <main>
    <div class="page-content">
      <h1>Thanks for reaching out.</h1>
      <p>I'll be in touch in a few days.</p>
    </div>
  </main>
</BaseLayout>

<style>
  .page-content {
    max-width: 780px;
    padding: 0 30px 80px;
  }
</style>
