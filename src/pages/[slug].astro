---
import { getCollection, render } from 'astro:content';
import TripLayout from '../layouts/TripLayout.astro';
import EssayLayout from '../layouts/EssayLayout.astro';

export async function getStaticPaths() {
  const trips = await getCollection('trips');
  const writing = await getCollection('writing', ({ data }) => !data.draft);

  const sortedTrips = [...trips].sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
  const tripPaths = trips.map(trip => {
    const idx = sortedTrips.findIndex(t => t.id === trip.id);
    const nextEntry = sortedTrips.length > 1 ? sortedTrips[(idx + 1) % sortedTrips.length] : null;
    const prevEntry = sortedTrips.length > 1 ? sortedTrips[(idx - 1 + sortedTrips.length) % sortedTrips.length] : null;
    const nextPeer = nextEntry ? { title: nextEntry.data.title, permalink: `/${nextEntry.id.replace(/\.md$/, '')}` } : null;
    const prevPeer = prevEntry ? { title: prevEntry.data.title, permalink: `/${prevEntry.id.replace(/\.md$/, '')}` } : null;
    return {
      params: { slug: trip.id.replace(/\.md$/, '') },
      props: { type: 'trip' as const, entry: trip, nextPeer, prevPeer },
    };
  });

  const writingPaths = writing.map(entry => {
    const collectionEntries = writing
      .filter(e => e.data.collection === entry.data.collection)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
    const idx = collectionEntries.findIndex(e => e.id === entry.id);
    const nextEntry = collectionEntries.length > 1
      ? collectionEntries[(idx + 1) % collectionEntries.length]
      : null;
    const nextPeer = nextEntry
      ? { title: nextEntry.data.title, permalink: nextEntry.data.permalink }
      : null;
    const prevEntry = collectionEntries.length > 1
      ? collectionEntries[(idx - 1 + collectionEntries.length) % collectionEntries.length]
      : null;
    const prevPeer = prevEntry
      ? { title: prevEntry.data.title, permalink: prevEntry.data.permalink }
      : null;
    return {
      params: { slug: entry.data.permalink.replace(/^\//, '') },
      props: { type: 'writing' as const, entry, nextPeer, prevPeer },
    };
  });

  return [...tripPaths, ...writingPaths];
}

const { type, entry, nextPeer, prevPeer } = Astro.props;
const { Content } = await render(entry);
---

{type === 'trip' ? (
  <TripLayout
    title={entry.data.title}
    description={entry.data.description}
    canonicalUrl={entry.data.canonicalUrl}
    nextPeer={nextPeer}
    prevPeer={prevPeer}
  >
    <Content />
  </TripLayout>
) : (
  <EssayLayout
    title={entry.data.title}
    description={entry.data.description}
    collection={entry.data.collection}
    date={entry.data.date}
    permalink={entry.data.permalink}
    nextPeer={nextPeer}
    prevPeer={prevPeer}
  >
    <Content />
  </EssayLayout>
)}
