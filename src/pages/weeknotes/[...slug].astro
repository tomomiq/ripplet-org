---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import WeeknotesEntry from '../../components/WeeknotesEntry.astro';
import NewsletterFooter from '../../components/NewsletterFooter.astro';
import { getCollection, render } from 'astro:content';
import { fetchBooks } from '../../lib/books';
import { fetchWeatherForPost } from '../../lib/weather';

export async function getStaticPaths() {
  const allPosts = await getCollection('weeknotes');
  const posts = allPosts.filter(p => !p.data.draft);
  posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return posts.map((post, i) => ({
    params: { slug: post.data.permalink.replace(/^\/weeknotes\//, '') },
    props: {
      post,
      prev: posts[i - 1] ?? null,
      next: posts[i + 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const isbns = post.data.isbn
  ? (Array.isArray(post.data.isbn) ? post.data.isbn : [post.data.isbn])
  : [];
const books = await fetchBooks(isbns);
const weather = post.data.location
  ? await fetchWeatherForPost(post.data.location, post.data.pubDate)
  : null;
---
<BaseLayout title={`${post.data.week} — ${post.data.title}`} rssUrl="/weeknotes/rss.xml">
  <Header currentPath="/weeknotes" />
  <main>
    <WeeknotesEntry post={post} Content={Content} books={books} weather={weather} />
    <nav class="pagination">
      {prev
        ? <a href={prev.data.permalink} class="prev">← {prev.data.title}</a>
        : <span />}
      {next
        ? <a href={next.data.permalink} class="next">{next.data.title} →</a>
        : <span />}
    </nav>
    <div style="max-width: 780px; margin: 0 auto; padding: 0 30px 80px;">
      <NewsletterFooter />
    </div>
  </main>
</BaseLayout>

<style>
  .pagination {
    display: flex;
    justify-content: center;
    gap: 48px;
    align-items: center;
    max-width: 720px;
    margin: 140px auto 80px;
    padding: 0 30px;
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .pagination { padding: 0 20px; }
  }

  @media (max-width: 480px) {
    .pagination { padding: 0 16px; margin-top: 44px; }
  }
</style>
