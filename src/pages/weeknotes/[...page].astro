---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import WeeknotesEntry from '../../components/WeeknotesEntry.astro';
import NewsletterFooter from '../../components/NewsletterFooter.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { fetchBooks } from '../../lib/books';
import { fetchWeatherForPost } from '../../lib/weather';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPosts = await getCollection('weeknotes');
  const posts = allPosts.filter(p => !p.data.draft);
  posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(posts, { pageSize: 10 });
};

const { page } = Astro.props;

const rendered = await Promise.all(
  page.data.map(async (post) => {
    const { Content } = await render(post);
    const isbns = post.data.isbn
      ? (Array.isArray(post.data.isbn) ? post.data.isbn : [post.data.isbn])
      : [];
    const books = await fetchBooks(isbns);
    const weather = post.data.location
      ? await fetchWeatherForPost(post.data.location, post.data.pubDate)
      : null;
    return { post, Content, books, weather };
  })
);
---
<BaseLayout
  title="Weeknotes"
  rssUrl="/weeknotes/rss.xml"
  description="Weeknotes by Tomomi Sasaki, a designer, coach and facilitator based in Paris."
  canonicalUrl="https://www.ripplet.org/weeknotes"
>
  <Header currentPath="/weeknotes" />
  <main>
    <div class="river">
      {rendered.map(({ post, Content, books, weather }) => (
        <WeeknotesEntry post={post} Content={Content} books={books} weather={weather} isListView />
      ))}
    </div>
    {(page.url.prev || page.url.next) && (
      <nav class="pagination">
        {page.url.prev
          ? <a href={page.url.prev}>← Newer</a>
          : <span />}
        {page.url.next
          ? <a href={page.url.next}>Older →</a>
          : <span />}
      </nav>
    )}
    <div style="max-width: 780px; margin: 0 auto; padding: 0 30px 80px;">
      <NewsletterFooter />
    </div>
  </main>
</BaseLayout>

<style>
  .river {
    padding-bottom: 100px;
  }

  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 720px;
    margin: 0 auto 80px;
    padding: 0 30px;
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .river { padding-bottom: 60px; }
    .pagination { padding: 0 20px; }
  }

  @media (max-width: 480px) {
    .river { padding-bottom: 48px; }
    .pagination { padding: 0 16px; }
  }
</style>
