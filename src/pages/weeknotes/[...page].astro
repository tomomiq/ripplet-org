---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { fetchBooks } from '../../lib/books';
import { fetchWeatherForPost } from '../../lib/weather';

function ordinal(d: number) {
  const s = d === 1 || d === 21 || d === 31 ? 'st'
          : d === 2 || d === 22 ? 'nd'
          : d === 3 || d === 23 ? 'rd' : 'th';
  return `${d}${s}`;
}
function formatPubDate(date: Date) {
  const month = date.toLocaleDateString('en-GB', { month: 'long' });
  return `${month} ${ordinal(date.getDate())}`;
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPosts = await getCollection('weeknotes');
  const posts = allPosts.filter(p => !p.data.draft);
  posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(posts, { pageSize: 10 });
};

const { page } = Astro.props;

const rendered = await Promise.all(
  page.data.map(async (post) => {
    const { Content } = await render(post);
    const isbns = post.data.isbn
      ? (Array.isArray(post.data.isbn) ? post.data.isbn : [post.data.isbn])
      : [];
    const books = await fetchBooks(isbns);
    const weather = post.data.location
      ? await fetchWeatherForPost(post.data.location, post.data.pubDate)
      : null;
    return { post, Content, books, weather };
  })
);
---
<BaseLayout title="Weeknotes" rssUrl="/weeknotes/rss.xml">
  <Header currentPath="/weeknotes" />
  <main>
    <div class="river">
      {rendered.map(({ post, Content, books, weather }) => (
        <article class="river-entry">
          {post.data.image && (
            <div class="river-img-wrap">
              <img class="river-img" src={`/weeknotes-images/${post.data.image}`} alt="" />
              {post.data.caption && <p class="river-caption">{post.data.caption}</p>}
            </div>
          )}
          <div class="river-text">
            <div class="river-week">
              {post.data.week}
              {post.data.location && <span class="location"> in {post.data.location}</span>}
              <span class="pubdate"> — Published {formatPubDate(post.data.pubDate)}</span>
              {weather && <span class="weather"> {weather.icon} {weather.temp}°C</span>}
            </div>
            <h2 class="river-title"><a href={post.data.permalink}>{post.data.title}</a></h2>
            <div class="river-body">
              <Content />
            </div>
            {books.length > 0 && (
              <div class="books-section">
                <div class="books-heading">Books</div>
                <div class="books-grid">
                  {books.map(b => (
                    <div class="book-card">
                      {b.coverUrl
                        ? <img class="book-cover" src={b.coverUrl} alt=""
                            onerror="this.outerHTML='<div class=\'book-cover-placeholder\'></div>'" />
                        : <div class="book-cover-placeholder" />}
                      <div class="book-title">
                        {b.infoUrl
                          ? <a href={b.infoUrl} target="_blank" rel="noopener">{b.title ?? '(unknown)'}</a>
                          : (b.title ?? '(unknown)')}
                      </div>
                      {b.author && <div class="book-author">{b.author}</div>}
                      {(b.publisher || b.year) && (
                        <div class="book-pub">{[b.publisher, b.year].filter(Boolean).join(', ')}</div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
    {(page.url.prev || page.url.next) && (
      <nav class="pagination">
        {page.url.prev
          ? <a href={page.url.prev}>← Newer</a>
          : <span />}
        {page.url.next
          ? <a href={page.url.next}>Older →</a>
          : <span />}
      </nav>
    )}
  </main>
</BaseLayout>

<style>
  .river {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 30px 100px;
  }

  .river-entry {
    padding-bottom: 72px;
    margin-bottom: 72px;
  }

  .river-entry:last-child { padding-bottom: 0; }

  .river-img-wrap { margin-bottom: 28px; }

  .river-img {
    width: 100%;
    display: block;
  }

  .river-caption {
    font-size: 12px;
    color: #999;
    margin-top: 8px;
  }

  .river-text {
    max-width: 720px;
    margin: 0 auto;
  }

  .river-week {
    font-size: 12px;
    letter-spacing: 0.5px;
    color: #666;
    margin-bottom: 8px;
  }

  .river-week .location {
    color: #999;
    font-weight: 400;
  }

  .river-week .pubdate {
    color: #999;
    font-weight: 400;
  }

  .river-week .weather {
    color: #999;
    font-weight: 400;
  }

  .river-title {
    font-size: 28px;
    font-weight: 700;
    line-height: 1.25em;
    margin: 0 0 28px;
    color: #111;
  }

  .river-title a { color: inherit; }
  .river-title a:hover { opacity: 0.6; }

  .river-body {
    font-size: 17px;
    line-height: 1.78em;
    color: #333;
  }

  .river-body :global(a) { color: inherit; text-decoration: underline; }
  .river-body :global(a:hover) { opacity: 0.6; }

  .river-body :global(p) { margin: 0 0 20px; }
  .river-body :global(p:last-child) { margin-bottom: 0; }
  .river-body :global(ul) { margin: 0 0 20px; padding-left: 22px; }
  .river-body :global(ul li) { margin-bottom: 12px; }
  .river-body :global(img) { display: none; }

  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 720px;
    margin: 0 auto 80px;
    padding: 0 30px;
    font-size: 14px;
  }

  /* ── Books section ── */
  .books-section {
    margin-top: 40px;
  }

  .books-heading {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 8px;
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .book-card {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .book-cover,
  .book-cover-placeholder {
    width: 100%;
    aspect-ratio: 2/3;
    margin-bottom: 10px;
  }

  .book-cover {
    object-fit: contain;
    background: #f5f5f5;
    display: block;
  }

  .book-cover-placeholder {
    background: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #bbb;
    letter-spacing: 0.5px;
  }
  .book-cover-placeholder::after { content: 'no cover'; }

  .book-title {
    font-size: 13px;
    font-weight: 600;
    color: #111;
    line-height: 1.6em;
  }

  .book-title a {
    color: inherit;
    text-decoration: none;
  }
  .book-title a:hover { text-decoration: underline; }

  .book-author {
    font-size: 12px;
    color: #666;
    line-height: 1.8;
  }

  .book-pub {
    font-size: 11px;
    color: #aaa;
    line-height: 2.0;
  }

  /* ── Tablet ── */
  @media (max-width: 768px) {
    .river { padding: 0 20px 60px; }
    .river-entry { padding-bottom: 52px; margin-bottom: 52px; }
    .river-img-wrap { margin-left: -20px; margin-right: -20px; }
    .river-caption { padding-left: 20px; padding-right: 20px; }
    .river-title { font-size: 24px; }
    .river-text { max-width: 100%; }
    .pagination { padding: 0 20px; }
  }

  /* ── Phone ── */
  @media (max-width: 480px) {
    .river { padding: 0 16px 48px; }
    .river-entry { padding-bottom: 44px; margin-bottom: 44px; }
    .river-img-wrap { margin-left: -16px; margin-right: -16px; margin-bottom: 20px; }
    .river-caption { padding-left: 16px; padding-right: 16px; }
    .river-title { font-size: 22px; margin-bottom: 20px; }
    .river-body { font-size: 16px; line-height: 1.7em; }
    .river-body :global(p) { margin-bottom: 16px; }
    .river-week { margin-bottom: 6px; }
    .pagination { padding: 0 16px; }
    .books-grid {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      gap: 16px;
      margin: 0 -16px;
      padding: 0 16px 12px;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .books-grid::-webkit-scrollbar { display: none; }
    .book-card {
      min-width: 120px;
      max-width: 120px;
    }
  }
</style>
