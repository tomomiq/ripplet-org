<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Umami opt-out</title>
</head>
<body>
  <p id="msg">Setting opt-out cookie...</p>
  <script>
    document.cookie = 'umami.disabled=1; expires=Fri, 31 Dec 9999 23:59:59 GMT; path=/; domain=.ripplet.org';
    document.getElementById('msg').textContent = 'Done — this browser will no longer be tracked.';
  </script>
</body>
</html>
