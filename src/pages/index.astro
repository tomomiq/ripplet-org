---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import NewsletterFooter from '../components/NewsletterFooter.astro';
import { readdirSync } from 'fs';
import { join } from 'path';

let images: string[] = [];
try {
  const imgDir = join(process.cwd(), 'public/home');
  images = readdirSync(imgDir)
    .filter(f => /\.(jpg|jpeg|png|webp)$/i.test(f))
    .sort()
    .slice(0, 9)
    .map(f => `/home/${f}`);
} catch {
  // folder missing or empty — show nothing
}

let recentNewsletters: { title: string; link: string; date: string }[] = [];
try {
  const res = await fetch('https://buttondown.email/tomomiq/rss');
  const xml = await res.text();
  const itemMatches = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)].slice(0, 3);
  for (const [, item] of itemMatches) {
    const title = item.match(/<title>(?:<!\[CDATA\[)?(.*?)(?:\]\]>)?<\/title>/)?.[1]?.trim();
    const link = item.match(/<link>(.*?)<\/link>/)?.[1]?.trim();
    const pubDate = item.match(/<pubDate>(.*?)<\/pubDate>/)?.[1];
    if (title && link && pubDate) {
      recentNewsletters.push({
        title,
        link,
        date: new Date(pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
      });
    }
  }
} catch {
  // RSS fetch failed — show fallback
}
---
<BaseLayout title="Hi, my name is Tomomi." description="Tomomi Sasaki is a designer, coach and facilitator based in Paris.">
  <Header currentPath="/" />
  <main>
    <div class="page-content">
      <div class="intro">
        <p>I'm a designer, coach and facilitator based in Paris, interested in how we design the conditions for independent-minded individuals to grow and thrive together. Actively exploring: learning as a social activity, the nature of unfolding conversations, and building better habits for effective collaboration.</p>
        <p><strong>Right now, I'm working on:</strong></p>
        <div class="now-grid">
          <p>😎 Leading client assignments at <strong><a href="https://aqworks.com">AQ</a></strong>, the independent design and research studio where I am partner.</p>
          <p>🔑 Learning about myself and human systems in the <strong><a href="https://www.igoldcenter.com/programs/igold-program">iGOLD program</a></strong> (International Gestalt Organization and Leadership Development Program).</p>
          <p>🚠 Running workshops at <strong><a href="https://emotions-atwork.com">Emotions at Work</a></strong> to open new ways to think, talk, and act on the emotional landscape of our working lives.</p>
          <p>🚴‍♀️ Building "tools for people who work with people" while growing first-principles fluency with agentic systems. Check out my <strong><a href="https://build.ripplet.org/">project portfolio and notebook.</a></strong></p>
        </div>
        <div class="postcards-box">
          <div class="postcards-meta">
            <div class="postcards-label"><a href="https://buttondown.com/tomomiq/" target="_blank" rel="noopener" class="postcards-label-link">Postcards from Tomomi</a></div>
            <p class="postcards-desc">The occasional update and invitations to play together.</p>
          </div>
          <ul class="postcards-list">
            {recentNewsletters.length > 0 ? recentNewsletters.map(n => (
              <li>
                <a href={n.link} target="_blank" rel="noopener">
                  <span class="postcards-issue-title">{n.title}</span>
                  <span class="postcards-issue-date">{n.date}</span>
                </a>
              </li>
            )) : (
              <li><a href="https://buttondown.email/tomomiq/archive/" target="_blank" rel="noopener">Browse the archive</a></li>
            )}
          </ul>
        </div>
      </div>

      {images.length > 0 && (
        <div class="instagram-grid">
          {images.map((src) => (
            <img src={src} alt="" loading="lazy" />
          ))}
        </div>
      )}
      <NewsletterFooter />
    </div>
  </main>
</BaseLayout>

<style>
  .page-content { max-width: 960px; }

  .intro { margin-bottom: 60px; }

  .now-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px 52px;
    margin: 16px 0 0;
  }

  .now-grid p { margin: 0; }

  .postcards-box {
    background: #f5f5f5;
    padding: 20px 28px;
    margin: 60px 0 0;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 0 40px;
    align-items: center;
  }

  .postcards-meta {
    border-right: 1px solid #ddd;
    padding-right: 24px;
  }

  .postcards-label-link {
    color: inherit;
    text-decoration: none;
  }

  .postcards-label-link:hover { opacity: 0.6; }

  .postcards-label {
    font-size: 17px;
    font-weight: 700;
    color: #111;
    margin-bottom: 4px;
  }

  .postcards-desc {
    font-size: 13px;
    color: #666;
    margin: 4px 0 0;
    line-height: 1.3;
  }

  .postcards-list {
    list-style: none;
    padding: 0 !important;
    margin: 0;
  }

  .postcards-list li::before { display: none !important; }

  .postcards-list li {
    padding: 6px 0;
    border-bottom: 1px solid #fff;
  }

  .postcards-list li:last-child { border-bottom: none; }

  .postcards-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    font-size: 14px;
    color: inherit;
    text-decoration: none;
  }

  .postcards-list a:hover { opacity: 0.6; }

  .postcards-issue-date {
    font-size: 12px;
    color: #999;
    flex-shrink: 0;
  }

  .instagram-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin: 40px 0 0;
  }

  .instagram-grid img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 600px) {
    .now-grid { grid-template-columns: 1fr; }
    .instagram-grid { grid-template-columns: repeat(2, 1fr); }
    .postcards-box { grid-template-columns: 1fr; gap: 16px 0; }
    .postcards-meta { border-right: none; padding-right: 0; }
    .postcards-list a { flex-direction: column; gap: 2px; }
  }
</style>
