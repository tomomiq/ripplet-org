---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import NewsletterFooter from '../../components/NewsletterFooter.astro';

export async function getStaticPaths() {
  const entries = await getCollection('ls');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allEntries = await getCollection('ls');
const entryMap = Object.fromEntries(allEntries.map(e => [e.id, e]));

const MICROSTRUCTURES = [
  'helping-heuristics', 'nine-whys', 'appreciative-interviews', 'ecocycle-planning',
  'celebrity-interview', '25-10-crowdsourcing', 'open-space-technology', 'wise-crowds',
  'wicked-questions', 'heard-seen-respected', '15percent-solutions', 'triz',
  'min-specs', 'user-experience-fishbowl', 'conversation-cafe', 'troika-consulting',
  'impromptu-networking', '1-2-4-all',
];

const UNDER_DEVELOPMENT = [
  'tiny-monsters', 'narrative-reauthoring', 'spiral-journal', 'mad-tea-party',
];
---

<BaseLayout
  title={entry.data.title}
  description={`Field notes from Tomomi's Liberating Structures practice — ${entry.data.title}.`}
  canonicalUrl={`https://www.ripplet.org/liberating-structures/${entry.id}`}
>
  <Header currentPath="/liberating-structures" />
  <div class="article-layout">

    <article class="article-body">
      {entry.data.image && (
        <img
          class="article-icon"
          src={`/liberating-structures/images/${entry.data.image}`}
          alt={`${entry.data.title} illustration`}
        />
      )}
      <h1 class="entry-title">{entry.data.title}</h1>

      {entry.data.instructions_url && (
        <p class="see-instructions">
          <a href={entry.data.instructions_url}>For activity instructions, go to liberatingstructures.com →</a>
        </p>
      )}

      <Content />

      <p class="series-context">This entry is part of <a href="/liberating-structures">Liberating Structures Field Notes</a>, my collection of stories and reflections from the field. It's written for people who already know LS and are deepening their practice. If you're just getting started and looking for activity instructions, you'll find them at <a href="liberatingstructures.com">liberatingstructures.com.</a>.</p>


    </article>

    <aside class="article-sidebar">
      <div class="sidebar-section">
        <h4>Microstructures</h4>
        <ul>
          {MICROSTRUCTURES.map(id => {
            const e = entryMap[id];
            const title = e?.data.title ?? id;
            const href = e ? `/liberating-structures/${id}` : '#';
            return (
              <li class={entry.id === id ? 'current' : ''}>
                <a href={href}>{title}</a>
              </li>
            );
          })}
        </ul>
      </div>

      <div class="sidebar-section">
        <h4>LS under development</h4>
        <ul>
          {UNDER_DEVELOPMENT.map(id => {
            const e = entryMap[id];
            const title = e?.data.title ?? id;
            const href = e ? `/liberating-structures/${id}` : '#';
            return (
              <li class={entry.id === id ? 'current' : ''}>
                <a href={href}>{title}</a>
              </li>
            );
          })}
        </ul>
      </div>
    </aside>

  </div>
  <NewsletterFooter maxWidth="1100px" />
</BaseLayout>

<style>
  .article-icon {
    display: block;
    width: 73px;
    height: 72px;
    object-fit: contain;
    margin-bottom: 20px;
  }


  .article-layout {
    max-width: 1100px;
    margin: 0 auto;
    padding: 60px 30px 0;
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 80px;
    align-items: start;
  }

  .series-context {
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px solid #eee;
    font-size: 14px;
    color: #555;
  }

  .series-context a { color: inherit; text-decoration: underline; }
  .series-context a:hover { opacity: 0.6; }

  .article-body h1.entry-title {
    font-size: 38px;
    font-weight: 700;
    line-height: 1.25em;
    margin: 0 0 24px;
  }

  .article-body :global(h2) { font-size: 19px; font-weight: 700; margin: 40px 0 14px; }
  .article-body :global(h3) { font-size: 15px; font-weight: 700; margin: 32px 0 10px; }

  .article-body p { margin: 0 0 20px; }

  .article-body ul { margin: 0 0 24px; padding-left: 24px; }
  .article-body ul li { margin-bottom: 12px; }

  .article-body :global(a) { color: inherit; text-decoration: underline; }
  .article-body :global(a:hover) { opacity: 0.6; }

  .see-instructions {
    padding: 10px 0;
    border-top: 1px solid #eee;
    border-bottom: 1px solid #eee;
    font-size: 13px;
    margin: 0 0 20px;
  }

  .article-sidebar {
    position: sticky;
    top: 40px;
  }

  .sidebar-section { margin-bottom: 36px; }

  .sidebar-section h4 {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #999;
    margin: 0 0 12px;
  }

  .sidebar-section ul { list-style: none; margin: 0; padding: 0; }
  .sidebar-section ul li { margin-bottom: 4px; }
  .sidebar-section ul li a { font-size: 13px; color: #222; text-decoration: underline; }
  .sidebar-section ul li a:hover { opacity: 0.6; }
  .sidebar-section ul li.current a { font-weight: 700; color: #222; }

  @media (max-width: 768px) {
    .article-layout {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 40px 20px 60px;
    }

    .article-body h1.entry-title { font-size: 26px; margin: 0 0 20px; }
    .article-body h2 { font-size: 17px; }

    .article-sidebar {
      position: static;
      border-top: 1px solid #eee;
      padding-top: 40px;
      margin-top: 40px;
    }
  }
</style>
