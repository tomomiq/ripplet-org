---
import type { CollectionEntry } from 'astro:content';
import type { BookData } from '../lib/books';
import type { WeatherData } from '../lib/weather';

interface Props {
  post: CollectionEntry<'weeknotes'>;
  Content: any;
  books: BookData[];
  weather: WeatherData | null;
  isListView?: boolean;
}

const { post, Content, books, weather, isListView = false } = Astro.props;

function ordinal(d: number) {
  const s = d === 1 || d === 21 || d === 31 ? 'st'
          : d === 2 || d === 22 ? 'nd'
          : d === 3 || d === 23 ? 'rd' : 'th';
  return `${d}${s}`;
}
function formatPubDate(date: Date) {
  const month = date.toLocaleDateString('en-GB', { month: 'long' });
  return `${month} ${ordinal(date.getDate())}`;
}
---

<article class:list={['entry', isListView && 'entry--list']}>
  {post.data.image && (
    <div class="entry-img-wrap">
      <img class="entry-img" src={`/weeknotes-images/${post.data.image}`} alt="" />
      {post.data.caption && <p class="entry-caption">{post.data.caption}</p>}
    </div>
  )}
  <div class="entry-text">
    <div class="entry-week">
      {post.data.week}
      {post.data.location && <span class="location"> in {post.data.location}</span>}
      <span class="pubdate"> — Published {formatPubDate(post.data.pubDate)}</span>
      {weather && <span class="weather"> {weather.icon} {weather.temp}°C</span>}
    </div>
    {isListView
      ? <h2 class="entry-title"><a href={post.data.permalink}>{post.data.title}</a></h2>
      : <h1 class="entry-title">{post.data.title}</h1>}
    <div class="entry-body"><Content /></div>
    {books.length > 0 && (
      <div class="books-section">
        <div class="books-heading">Books</div>
        <div class="books-grid">
          {books.map(b => (
            <div class="book-card">
              {b.coverUrl
                ? <img class="book-cover" src={b.coverUrl} alt=""
                    onerror="this.outerHTML='<div class=\'book-cover-placeholder\'></div>'" />
                : <div class="book-cover-placeholder" />}
              <div class="book-title">
                {b.infoUrl
                  ? <a href={b.infoUrl} target="_blank" rel="noopener">{b.title ?? '(unknown)'}</a>
                  : (b.title ?? '(unknown)')}
              </div>
              {b.author && <div class="book-author">{b.author}</div>}
              {(b.publisher || b.year) && (
                <div class="book-pub">{[b.publisher, b.year].filter(Boolean).join(', ')}</div>
              )}
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</article>

<style>
  .entry {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .entry--list {
    padding-bottom: 72px;
    margin-bottom: 72px;
  }

  .entry--list:last-child { padding-bottom: 0; }

  .entry-img-wrap { margin-bottom: 28px; }

  .entry-img {
    width: 100%;
    display: block;
  }

  .entry-caption {
    font-size: 12px;
    color: #999;
    margin-top: 8px;
  }

  .entry-text {
    max-width: 720px;
    margin: 0 auto;
  }

  .entry-week {
    font-size: 12px;
    letter-spacing: 0.5px;
    color: #666;
    margin-bottom: 8px;
  }

  .entry-week .location { color: #999; font-weight: 400; }
  .entry-week .pubdate { color: #999; font-weight: 400; }
  .entry-week .weather { color: #999; font-weight: 400; }

  .entry-title {
    font-size: 28px;
    font-weight: 700;
    line-height: 1.25em;
    margin: 0 0 28px;
    color: #111;
  }

  .entry-title a { color: inherit; }
  .entry-title a:hover { opacity: 0.6; }

  .entry-body {
    font-size: 17px;
    line-height: 1.78em;
    color: #333;
  }

  .entry-body :global(hr) {
    border: none;
    margin: calc(2em - 6px) 0 calc(2em + 20px);
    text-align: center;
    height: 0;
    overflow: visible;
  }
  .entry-body :global(hr)::before {
    content: '◆';
    display: inline-block;
    color: #bbb;
    font-size: 13px;
    letter-spacing: 2px;
  }

  .entry-body :global(a) { color: inherit; text-decoration: underline; }
  .entry-body :global(a:hover) { opacity: 0.6; }
  .entry-body :global(p) { margin: 0 0 20px; }
  .entry-body :global(p:last-child) { margin-bottom: 0; }
  .entry-body :global(ul) { margin: 0 0 20px; padding-left: 22px; }
  .entry-body :global(ul li) { margin-bottom: 12px; }

  .entry-body :global(p):has(img) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }
  .entry-body :global(p):has(img) :global(img) {
    width: 100%;
    display: block;
    aspect-ratio: 4/3;
    object-fit: cover;
    border: 1px solid #e0e0e0;
    padding: 6px;
    background: white;
    box-sizing: border-box;
  }

  /* ── Books section ── */
  .books-section { margin-top: 40px; }

  .books-heading {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 8px;
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .book-card {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .book-cover,
  .book-cover-placeholder {
    width: 100%;
    aspect-ratio: 2/3;
    margin-bottom: 10px;
  }

  .book-cover {
    object-fit: contain;
    background: #f5f5f5;
    display: block;
  }

  .book-cover-placeholder {
    background: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #bbb;
    letter-spacing: 0.5px;
  }
  .book-cover-placeholder::after { content: 'no cover'; }

  .book-title {
    font-size: 13px;
    font-weight: 600;
    color: #111;
    line-height: 1.6em;
  }

  .book-title a { color: inherit; text-decoration: none; }
  .book-title a:hover { text-decoration: underline; }

  .book-author {
    font-size: 12px;
    color: #666;
    line-height: 1.8;
  }

  .book-pub {
    font-size: 11px;
    color: #aaa;
    line-height: 2.0;
  }

  /* ── Tablet ── */
  @media (max-width: 768px) {
    .entry { padding: 0 20px; }
    .entry--list { padding-bottom: 52px; margin-bottom: 52px; }
    .entry-img-wrap { margin-left: -20px; margin-right: -20px; }
    .entry-caption { padding-left: 20px; padding-right: 20px; }
    .entry-title { font-size: 24px; }
    .entry-text { max-width: 100%; }
  }

  /* ── Phone ── */
  @media (max-width: 480px) {
    .entry { padding: 0 16px; }
    .entry--list { padding-bottom: 44px; margin-bottom: 44px; }
    .entry-img-wrap { margin-left: -16px; margin-right: -16px; margin-bottom: 20px; }
    .entry-caption { padding-left: 16px; padding-right: 16px; }
    .entry-title { font-size: 22px; margin-bottom: 20px; }
    .entry-body { font-size: 16px; line-height: 1.7em; }
    .entry-body :global(p) { margin-bottom: 16px; }

    .entry-week { margin-bottom: 6px; }
    .books-grid {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      gap: 16px;
      margin: 0 -16px;
      padding: 0 16px 12px;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .books-grid::-webkit-scrollbar { display: none; }
    .book-card {
      min-width: 120px;
      max-width: 120px;
    }
  }
</style>
