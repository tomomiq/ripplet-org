---
import type { CollectionEntry } from 'astro:content';
import type { BookData } from '../lib/books';
import type { WeatherData } from '../lib/weather';
interface Props {
  post: CollectionEntry<'weeknotes'>;
  Content: any;
  books: BookData[];
  weather: WeatherData | null;
  isListView?: boolean;
}

const { post, Content, books, weather, isListView = false } = Astro.props;

const fitness = (post.data as any).fitness ?? null;
const weekTypes = ['build', 'maintain', 'recovery'] as const;
const weekLabels: Record<string, string> = {
  build: 'Build week', maintain: 'Maintain week', recovery: 'Recovery week',
};
const dotColors: Record<string, string> = {
  build: '#5a9e52', maintain: '#c09a20', restore: '#9b7fc8', play: '#e07050',
};

function ordinal(d: number) {
  const s = d === 1 || d === 21 || d === 31 ? 'st'
          : d === 2 || d === 22 ? 'nd'
          : d === 3 || d === 23 ? 'rd' : 'th';
  return `${d}${s}`;
}
function formatPubDate(date: Date) {
  const month = date.toLocaleDateString('en-GB', { month: 'long' });
  return `${month} ${ordinal(date.getDate())}`;
}
---

<article class:list={['entry', isListView && 'entry--list']}>
  {post.data.image && (
    <div class="entry-img-wrap">
      <img class="entry-img" src={`/weeknotes-images/${post.data.image}`} alt="" loading={isListView ? 'lazy' : 'eager'} />
      {post.data.caption && <p class="entry-caption">{post.data.caption}</p>}
    </div>
  )}
  <div class="entry-text">
    <div class="entry-week">{post.data.week}</div>
    {isListView
      ? <h2 class="entry-title"><a href={post.data.permalink}>{post.data.title}</a></h2>
      : <h1 class="entry-title">{post.data.title}</h1>}
    <div class="entry-meta">
      Published <time datetime={post.data.pubDate.toISOString()}>{formatPubDate(post.data.pubDate)}</time>
      {weather
        ? <> — {weather.description}{post.data.location ? ` over ${post.data.location}` : ''} {weather.icon} {weather.temp}°C</>
        : post.data.location && <> in {post.data.location}</>}
    </div>
    <div class="entry-body"><Content /></div>
    {books.length > 0 && (
      <div class="books-section">
        <div class="section-heading">Books</div>
        <div class="books-grid">
          {books.map(b => (
            <div class="book-card">
              {b.coverUrl
                ? <img class="book-cover" src={b.coverUrl} alt="" loading="lazy" />
                : <div class="book-cover-placeholder" />}
              <div class="book-title">
                {b.infoUrl
                  ? <a href={b.infoUrl} target="_blank" rel="noopener">{b.title ?? '(unknown)'}</a>
                  : (b.title ?? '(unknown)')}
              </div>
              {b.author && <div class="book-author">{b.author}</div>}
              {(b.publisher || b.year) && (
                <div class="book-pub">{[b.publisher, b.year].filter(Boolean).join(', ')}</div>
              )}
            </div>
          ))}
        </div>
      </div>
    )}
    {fitness && (
      <div class="fitness-section">
        <div class="fitness-heading-wrap">
          <span class="section-heading">Fitness</span>
          <button class="fi-info" type="button" aria-label="Fitness key">ⓘ
            <div class="fi-tooltip">
              <div class="fi-tooltip-section">
                <div class="fi-tooltip-label">Goals</div>
                <div class="fi-tooltip-row"><strong>Build week</strong> — Increase capacity</div>
                <div class="fi-tooltip-row"><strong>Maintain week</strong> — Preserve capacity during travel or busy periods</div>
                <div class="fi-tooltip-row"><strong>Recovery week</strong> — Emerge with more energy</div>
              </div>
              <div class="fi-tooltip-section">
                <div class="fi-tooltip-label">Activity categories</div>
                <div class="fi-dot-row">
                  {Object.entries(dotColors).map(([name, color]) => (
                    <span class="fi-dot-item">
                      <span class="fi-dot-sm" style={`background:${color}`}></span>{name}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </button>
        </div>
        <div class="fitness-week-options">
          {weekTypes.map((type, i) => (
            <>
              {i > 0 && <span class="wo-sep"> / </span>}
              <span class={fitness.week_type === type ? 'wb-selected' : 'wb-unselected'}>
                {weekLabels[type]}
              </span>
            </>
          ))}
        </div>
        <div class="fitness-grid">
          {fitness.steps && (
            <div class="fitness-grid-item">
              <span>Avg steps/day: {fitness.steps.toLocaleString()}</span>
            </div>
          )}
          {fitness.activities?.map((a: any) => {
            const cats = (a.category ?? '').split(',').map((c: string) => c.trim()).filter(Boolean);
            const primary = cats[0];
            const secondary = cats[1];
            return (
              <div class="fitness-grid-item">
                <span>{a.activity.charAt(0).toUpperCase() + a.activity.slice(1)} × {a.count}</span>
                <span class="fi-dot-wrap">
                  {primary && <span class="fi-dot-primary" style={`background:${dotColors[primary] ?? '#ccc'}`}></span>}
                  {secondary && <span class="fi-dot-secondary" style={`background:${dotColors[secondary] ?? '#ccc'}`}></span>}
                </span>
              </div>
            );
          })}
        </div>
      </div>
    )}
  </div>
</article>

<script>
  document.querySelectorAll('.fi-info').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      btn.classList.toggle('active');
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('.fi-info').forEach(btn => btn.classList.remove('active'));
  });

  document.querySelectorAll('.book-cover').forEach((img) => {
    function replaceWithPlaceholder() {
      const placeholder = document.createElement('div');
      placeholder.className = 'book-cover-placeholder';
      img.replaceWith(placeholder);
    }
    if (img.complete && img.naturalWidth === 0) {
      replaceWithPlaceholder();
    } else {
      img.addEventListener('error', replaceWithPlaceholder);
    }
  });
</script>

<style>
  .entry {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .entry--list {
    padding-bottom: 72px;
    margin-bottom: 72px;
  }

  .entry--list:last-child { padding-bottom: 0; }

  .entry-img-wrap { margin-bottom: 28px; }

  .entry-img {
    width: 100%;
    display: block;
  }

  .entry-caption {
    font-size: 12px;
    color: #999;
    margin-top: 8px;
    font-style: italic;
  }

  .entry-text {
    max-width: 720px;
    margin: 0 auto;
  }

  .entry-week {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #111;
    margin-bottom: 2px;
  }

  .entry-title {
    font-size: 28px;
    font-weight: 700;
    line-height: 1.25em;
    margin: 0 0 4px;
    color: #111;
  }

  .entry-meta {
    font-size: 12px;
    color: #999;
    margin-bottom: 28px;
  }

  .entry-title a { color: inherit; text-decoration: none; }
  .entry-title a:hover { opacity: 0.6; }

  .entry-body {
    line-height: 1.78em;
    color: #333;
  }

  .entry-body :global(a) { color: inherit; }

  .entry-body :global(.image-row) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }
  .entry-body :global(.image-row) :global(figure) {
    width: 100%;
    display: block;
    aspect-ratio: 1/1;
    overflow: hidden;
    box-sizing: border-box;
    margin: 0;
  }
  .entry-body :global(.image-row) :global(figure img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .entry-body :global(.image-row) :global(figcaption) {
    display: none;
  }

  /* ── Books section ── */
  .books-section { margin-top: 40px; }

  .section-heading {
    font-size: 19px;
    font-weight: 700;
    line-height: 1;
    color: #111;
    margin-bottom: 8px;
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .book-card {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .book-cover,
  .book-cover-placeholder {
    width: 100%;
    aspect-ratio: 2/3;
    margin-bottom: 10px;
  }

  .book-cover {
    object-fit: contain;
    display: block;
    background: white;
    border: 1px solid #e0e0e0;
    padding: 6px;
    box-sizing: border-box;
  }

  .book-cover-placeholder {
    background: #f5f5f5;
    border: 1px solid #e0e0e0;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #bbb;
    letter-spacing: 0.5px;
  }
  .book-cover-placeholder::after { content: 'no cover'; }

  .book-title {
    font-size: 13px;
    font-weight: 600;
    color: #111;
    line-height: 1.6em;
  }

  .book-title a { color: inherit; text-decoration: none; }
  .book-title a:hover { text-decoration: underline; }

  .book-author {
    font-size: 12px;
    color: #666;
    line-height: 1.8;
  }

  .book-pub {
    font-size: 11px;
    color: #aaa;
    line-height: 2.0;
  }

  /* ── Fitness section ── */
  .fitness-section { margin-top: 40px; }

  .fitness-heading-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 8px;
    position: relative;
  }

  .fitness-heading-wrap .section-heading { margin-bottom: 0; }

  .fi-info {
    font-size: 11px;
    color: #bbb;
    cursor: default;
    line-height: 1;
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
  }

  .fi-info:hover { color: #888; }

  .fi-tooltip {
    display: none;
    position: absolute;
    left: 0;
    top: calc(100% + 8px);
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    padding: 14px 16px;
    width: 380px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    z-index: 10;
    font-size: 13px;
    line-height: 1.6;
    color: #444;
    text-align: left;
  }

  .fi-info:hover .fi-tooltip,
  .fi-info.active .fi-tooltip { display: block; }

  .fi-tooltip-section { margin-bottom: 12px; }
  .fi-tooltip-section:last-child { margin-bottom: 0; }

  .fi-tooltip-label {
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 6px;
  }

  .fi-tooltip-row { margin-bottom: 3px; }
  .fi-tooltip-row:last-child { margin-bottom: 0; }
  .fi-tooltip-row strong { color: #111; font-weight: 600; }

  .fi-dot-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin-top: 2px;
  }

  .fi-dot-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: #444;
  }

  .fi-dot-sm {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    display: inline-block;
  }

  .fitness-week-options {
    font-size: 13px;
    margin-bottom: 8px;
  }

  .wb-selected { color: #111; font-weight: 600; }
  .wb-unselected { color: #bbb; font-weight: 400; }
  .wo-sep { color: #ddd; }

  .fitness-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0 48px;
  }

  .fitness-grid-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 6px 0;
    border-bottom: 1px solid #f0f0f0;
    font-size: 13px;
    color: #444;
    line-height: 1.6;
  }

  .fi-dot-wrap {
    position: relative;
    width: 7px;
    height: 7px;
    flex-shrink: 0;
  }

  .fi-dot-primary,
  .fi-dot-secondary {
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    top: 0;
  }

  .fi-dot-primary { left: 0; z-index: 2; }
  .fi-dot-secondary { left: 4px; z-index: 1; }

  /* ── Tablet ── */
  @media (max-width: 768px) {
    .entry { padding: 0 20px; }
    .entry--list { padding-bottom: 52px; margin-bottom: 52px; }
    .entry-img-wrap { margin-left: -20px; margin-right: -20px; }
    .entry-caption { padding-left: 20px; padding-right: 20px; }
    .entry-title { font-size: 24px; }
    .entry-text { max-width: 100%; }
  }

  /* ── Phone ── */
  @media (max-width: 480px) {
    .entry { padding: 0 16px; }
    .entry--list { padding-bottom: 44px; margin-bottom: 44px; }
    .entry-img-wrap { margin-left: -16px; margin-right: -16px; margin-bottom: 20px; }
    .entry-caption { padding-left: 16px; padding-right: 16px; }
    .entry-title { font-size: 22px; }
    .entry-body { font-size: 16px; line-height: 1.7em; }
    .entry-body :global(p) { margin-bottom: 16px; }

    .books-grid {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      gap: 16px;
      margin: 0 -16px;
      padding: 0 16px 12px;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .books-grid::-webkit-scrollbar { display: none; }
    .book-card {
      min-width: 120px;
      max-width: 120px;
    }

    .fitness-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0 24px;
    }

    .fi-tooltip {
      width: calc(100vw - 48px);
    }
  }
</style>
