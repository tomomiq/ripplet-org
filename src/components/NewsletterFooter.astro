---
---
<hr class="hr-line" />
<div class="newsletter-footer" style="width: fit-content; margin: 0 0 0 auto;">
  <div class="newsletter-inner" style="padding: 0 0 40px 30px;">
    <img src="/postcard.jpeg" alt="" class="postcard-img" />
    <div class="newsletter-text">
      <h2>Stay in touch?</h2>
      <p>Receive seasonal <a href="https://buttondown.email/tomomiq/archive/">postcards</a> in your inbox.</p>
      <form
        action="https://buttondown.com/api/emails/embed-subscribe/tomomiq"
        method="post"
        class="embeddable-buttondown-form"
      >
        <div class="form-row">
          <input type="email" name="email" id="bd-email" placeholder="you@email.com" />
          <input type="submit" value="Sign up" />
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  :global(hr.hr-line) {
    margin: 100px 0 24px;
  }

  .newsletter-inner {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-24px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .postcard-img {
    width: 90px;
    flex-shrink: 0;
    display: block;
    opacity: 0;
  }

  .postcard-img.is-visible {
    animation: slideInLeft 0.5s ease-out both;
  }

  .newsletter-text h2 {
    font-size: 19px;
    font-weight: 700;
    margin: 0 0 6px;
  }

  .newsletter-text p {
    font-size: 15px;
    line-height: 1.45em;
    color: #555;
    margin: 0 0 10px;
  }

  .newsletter-text :global(a) { color: #222; text-decoration: underline; }
  .newsletter-text :global(a:hover) { opacity: 0.6; }

  .contact-nudge {
    font-size: 13px;
    color: #999;
    margin: 10px 0 0;
  }

  .form-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .form-row input[type="email"] {
    flex: 1;
    min-width: 180px;
    padding: 8px 10px;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    font-family: inherit;
    font-size: 13px;
  }

  .form-row input[type="submit"] {
    padding: 8px 16px;
    background: #222;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-family: inherit;
    font-size: 13px;
    cursor: pointer;
  }

  .form-row input[type="submit"]:hover { opacity: 0.85; }

  @media (max-width: 600px) {
    .newsletter-inner { flex-direction: column; padding-right: 30px; }
    .postcard-img { width: 100px; }
    .newsletter-footer { width: auto !important; margin: 0 !important; }
    .newsletter-text { width: 100%; }
    .form-row { flex-direction: column; }
    .form-row input[type="email"] { min-width: 0; }
    .form-row input[type="submit"] { align-self: flex-start; }
  }
</style>

<script>
  const img = document.querySelector('.postcard-img');
  if (img) {
    const observer = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        img.classList.add('is-visible');
        observer.disconnect();
      }
    }, { threshold: 0.2 });
    observer.observe(img);
  }
</script>
